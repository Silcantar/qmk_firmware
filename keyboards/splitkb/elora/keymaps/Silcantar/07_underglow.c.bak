#define LTHUMB_LED_INDEX 5
#define RTHUMB_LED_INDEX 11

#define DEFAULT_SAT	192
#define DEFAULT_VAL	128

// Underglow
layer_state_t layer_state_set_user(layer_state_t state) {
	switch (get_highest_layer(state)) {
	case _ALPHA:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (163, DEFAULT_SAT, DEFAULT_VAL);	// Blue
		break;
	case _NUMERIC:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (113, DEFAULT_SAT, DEFAULT_VAL);	// Cyan
		break;
	case _FUNCTION:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (88, DEFAULT_SAT, DEFAULT_VAL);		// Green
		break;
	case _MOUSE:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (13, DEFAULT_SAT, DEFAULT_VAL);		// Orange
		break;
	case _WINMAN:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (188, DEFAULT_SAT, DEFAULT_VAL);	// Purple
		break;
/*	case _GREEK:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (138, DEFAULT_SAT, DEFAULT_VAL);	// Azure
		break;
	case _SYMBOL:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (38, DEFAULT_SAT, DEFAULT_VAL);		// Gold
		break;
	case _TENGWAR:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (63, DEFAULT_SAT, DEFAULT_VAL);		// Chartreuse
		break;
	case _GAME:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (213, DEFAULT_SAT, DEFAULT_VAL);	// Magenta
		break;*/
	case _QWERTY:
		rgblight_mode(RGBLIGHT_MODE_STATIC_LIGHT);
		rgblight_sethsv (0, 0, DEFAULT_VAL);				// White
		break;
	}
	return state;
}

void caps_word_set_user(bool active) {
    if (active) {
        rgblight_sethsv_at(HSV_RED, LTHUMB_LED_INDEX);
        rgblight_sethsv_at(HSV_RED, RTHUMB_LED_INDEX);
    } else {
        rgblight_sethsv_at(rgblight_get_hue(), rgblight_get_sat(), rgblight_get_val(), LTHUMB_LED_INDEX);
        rgblight_sethsv_at(rgblight_get_hue(), rgblight_get_sat(), rgblight_get_val(), RTHUMB_LED_INDEX);
    }
}